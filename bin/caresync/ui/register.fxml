<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.*?>
<?import java.lang.String?>

<VBox alignment="CENTER" prefHeight="800.0" prefWidth="650.0" style="-fx-background-color: #f4f7f6; -fx-padding: 20;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="caresync.controller.RegisterController">
<VBox alignment="TOP_LEFT" maxWidth="580.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">

    <VBox alignment="CENTER" spacing="5.0">
        <Label text="CareSync" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #0359A4;" />
        <Label text="Create your account" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" />
    </VBox>

    <VBox spacing="5.0" maxWidth="Infinity">
        <Label text="Register As" style="-fx-text-fill: #555; -fx-font-size: 12px;" />
        <ComboBox fx:id="roleBox" onAction="#handleRoleSelection" maxWidth="Infinity" promptText="Select Role"
                  style="-fx-background-radius: 6; -fx-padding: 6; -fx-border-color: #0359A4; -fx-border-radius: 6; -fx-background-color: white;">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Patient" /><String fx:value="Doctor" />
                </FXCollections>
            </items>
        </ComboBox>
    </VBox>

    <GridPane hgap="20.0" vgap="15.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="50" />
            <ColumnConstraints percentWidth="50" />
        </columnConstraints>
        <children>
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Full Name" style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <TextField fx:id="nameField" promptText="Enter your full name" style="-fx-background-radius: 6; -fx-padding: 10; -fx-border-color: #ddd; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Email Address" style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <TextField fx:id="emailField" promptText="Enter your email" style="-fx-background-radius: 6; -fx-padding: 10; -fx-border-color: #ddd; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Phone Number" style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <TextField fx:id="phoneField" promptText="Enter phone number" style="-fx-background-radius: 6; -fx-padding: 10; -fx-border-color: #ddd; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="Username" style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <TextField fx:id="userField" promptText="Enter your username" style="-fx-background-radius: 6; -fx-padding: 10; -fx-border-color: #ddd; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label text="Password" style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <PasswordField fx:id="passField" promptText="Enter password" style="-fx-background-radius: 6; -fx-padding: 10; -fx-border-color: #ddd; -fx-border-radius: 6;" />
            </VBox>
            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label text="Confirm Password" style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <PasswordField fx:id="confirmPassField" promptText="Confirm your password" style="-fx-background-radius: 6; -fx-padding: 10; -fx-border-color: #ddd; -fx-border-radius: 6;" />
            </VBox>
        </children>
    </GridPane>

    <VBox fx:id="dynamicContentContainer" spacing="15.0" />

    <HBox spacing="15.0" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
        <children>
            <Button onAction="#backToLogin" text="CANCEL" prefWidth="150.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-padding: 12; -fx-font-weight: bold; -fx-cursor: hand;" />
            <Button onAction="#registerUser" text="REGISTER" prefWidth="150.0"
                    style="-fx-background-color: #0359A4; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" />
        </children>
    </HBox>
</VBox>

</VBox>