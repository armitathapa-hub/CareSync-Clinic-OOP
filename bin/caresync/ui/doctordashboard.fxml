<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="caresync.controller.DoctorDashboardController">
    
    <left>
        <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: #2c3e50; -fx-padding: 20 10;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 0 0 20 10;" text="CareSync" />
                
                <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 12px; -fx-padding: 10 0 0 10;" text="DOCTOR MENU" />
                
                <Button maxWidth="Infinity" onAction="#handleRefresh"
                        style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-alignment: CENTER-LEFT;"
                        text="Refresh" />
                
                <Button maxWidth="Infinity" onAction="#handleAssignedAppointment"
                        style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-alignment: CENTER-LEFT;"
                        text="Assigned Appointment" />
                
                <Button maxWidth="Infinity" onAction="#handleDailySchedules"
                        style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-alignment: CENTER-LEFT;"
                        text="Daily Schedules" />

                <Region VBox.vgrow="ALWAYS" />
                
                <Button onAction="#handleLogout" maxWidth="Infinity"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-alignment: CENTER-LEFT;"
                        text="Logout" />
            </children>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="20.0" style="-fx-padding: 30;">
            <children>
                <Label fx:id="welcomeLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Welcome, Doctor!" />
                
                <HBox spacing="20.0">
                    <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label text="Today's Appointments" style="-fx-text-fill: #7f8c8d;" />
                        <Label fx:id="todayAppointments" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                    </VBox>
                    
                    <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label text="Pending Approvals" style="-fx-text-fill: #7f8c8d;" />
                        <Label fx:id="pendingAppointments" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
                    </VBox>
                    
                    <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label text="Total Patients" style="-fx-text-fill: #7f8c8d;" />
                        <Label fx:id="totalPatients" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                    </VBox>
                </HBox>
                
                <Label text="My Appointments" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                
                <TableView fx:id="appointmentsTable" prefHeight="400.0">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                        <TableColumn fx:id="colPatient" text="Patient" prefWidth="150" />
                        <TableColumn fx:id="colDate" text="Date" prefWidth="100" />
                        <TableColumn fx:id="colTime" text="Time" prefWidth="80" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
                        <TableColumn fx:id="colDescription" text="Description" prefWidth="200" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>