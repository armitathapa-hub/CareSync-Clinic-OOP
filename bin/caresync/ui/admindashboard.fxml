<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="caresync.controller.AdminDashboardController">
    
    <left>
        <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: #2c3e50; -fx-padding: 20 10;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 0 0 20 10;" text="CareSync" />
                
                <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 12px; -fx-padding: 10 0 0 10;" text="MAIN MENU" />
                
                <Button maxWidth="Infinity" onAction="#handleManageAppointments"
                        style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-alignment: CENTER-LEFT;"
                        text=" Manage Appointments" />
                        
                <Button maxWidth="Infinity" onAction="#handleManageUsers"
                        style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-alignment: CENTER-LEFT;"
                        text="Manage Users" />
                        
                <Button maxWidth="Infinity" onAction="#handleAppointmentRequest"
                        style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-alignment: CENTER-LEFT;"
                        text="Appointment Request" />

                <Region VBox.vgrow="ALWAYS" />
                
                <Button onAction="#handleLogout" maxWidth="Infinity"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-alignment: CENTER-LEFT;"
                        text="Logout" />
            </children>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="25.0" style="-fx-padding: 30;">
            <children>
                <Label fx:id="welcomeLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Welcome, Admin!" />
                
                <HBox spacing="20.0" alignment="CENTER">
                    <children>
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label text="Total Appointments" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="totalAppointments" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        </VBox>
                        
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label text="Pending" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="pendingAppointments" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
                        </VBox>
                        
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label text="Approved" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="approvedAppointments" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                        </VBox>
                        
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label text="Patients" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="totalPatients" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                        </VBox>
                        
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label text="Doctors" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="totalDoctors" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;" />
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>