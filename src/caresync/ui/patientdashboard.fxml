<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1050.0"
            style="-fx-background-color: #f0f4f8;"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="caresync.controller.PatientDashboardController">

    <!-- Sidebar -->
    <left>
        <VBox prefWidth="235.0" spacing="6.0"
              style="-fx-background-color: #0B2E5E; -fx-padding: 0;">

            <!-- Logo Area -->
            <VBox alignment="CENTER" spacing="4"
                  style="-fx-background-color: #0a2550; -fx-padding: 28 16 22 16;">
                <Label text="🏥" style="-fx-font-size: 32px;" />
                <Label text="CareSync"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                <Label text="Patient Portal"
                       style="-fx-text-fill: #7fafd4; -fx-font-size: 11px;" />
            </VBox>

            <VBox spacing="4" style="-fx-padding: 18 10 10 10;">
                <Label text="PATIENT MENU"
                       style="-fx-text-fill: #5a8ab0; -fx-font-size: 10px;
                              -fx-font-weight: bold; -fx-padding: 0 0 6 6;" />

                <Button fx:id="bookAppointmentBtn" maxWidth="Infinity"
                        onAction="#openBookingModal"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 13 16;
                               -fx-alignment: CENTER-LEFT; -fx-font-size: 13px;
                               -fx-font-weight: bold; -fx-cursor: hand;"
                        text="Book Appointment" />

                <Button fx:id="viewStatusBtn" maxWidth="Infinity"
                        onAction="#viewAppointmentStatus"
                        style="-fx-background-color: transparent; -fx-text-fill: #b8d4ee;
                               -fx-background-radius: 8; -fx-padding: 13 16;
                               -fx-alignment: CENTER-LEFT; -fx-font-size: 13px; -fx-cursor: hand;"
                        text="View My Status" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox style="-fx-padding: 10 10 20 10;">
                <Button onAction="#handleLogout" maxWidth="Infinity"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 12 16;
                               -fx-alignment: CENTER-LEFT; -fx-font-size: 13px;
                               -fx-font-weight: bold; -fx-cursor: hand;"
                        text="Logout" />
            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="22.0" style="-fx-padding: 32 36 32 36;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="14">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label fx:id="welcomeLabel"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0B2E5E;"
                           text="Welcome!" />
                    <Label text="Manage your appointments and health records below."
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;" />
                </VBox>
                <Button onAction="#openBookingModal"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 11 20;
                               -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"
                        text="Book New Appointment" />
            </HBox>

            <Separator style="-fx-background-color: #dde4ee;" />

            <!-- Appointments Section -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="My Appointments"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"
                           HBox.hgrow="ALWAYS" />
                    <Button onAction="#viewAppointmentStatus"
                            style="-fx-background-color: #0B2E5E; -fx-text-fill: white;
                                   -fx-background-radius: 6; -fx-padding: 7 14;
                                   -fx-font-size: 12px; -fx-cursor: hand;"
                            text="📊  Full Dashboard" />
                </HBox>

                <TableView fx:id="appointmentTable" prefHeight="370.0"
                           style="-fx-background-radius: 10; -fx-border-radius: 10;
                                  -fx-border-color: #dde4ee; -fx-background-color: white;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="55" />
                        <TableColumn fx:id="colDoctor" text="Doctor" prefWidth="200" />
                        <TableColumn fx:id="colDate" text="Date" prefWidth="120" />
                        <TableColumn fx:id="colTime" text="Time" prefWidth="90" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="120" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Label text="Click 'Full Dashboard' to view details and statistics"
                           style="-fx-text-fill: #aab4c2; -fx-font-size: 11px;" />
                </HBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>
