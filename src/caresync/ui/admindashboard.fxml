<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1050.0"
            style="-fx-background-color: #f0f4f8;"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="caresync.controller.AdminDashboardController">

    <!-- Sidebar -->
    <left>
        <VBox prefWidth="235.0" spacing="6.0"
              style="-fx-background-color: #0B2E5E; -fx-padding: 0;">

            <!-- Logo Area -->
            <VBox alignment="CENTER" spacing="4"
                  style="-fx-background-color: #0a2550; -fx-padding: 28 16 22 16;">
                <Label text="🏥" style="-fx-font-size: 32px;" />
                <Label text="CareSync"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                <Label text="Admin Portal"
                       style="-fx-text-fill: #7fafd4; -fx-font-size: 11px;" />
            </VBox>

            <VBox spacing="4" style="-fx-padding: 18 10 10 10;">
                <Label text="MAIN MENU"
                       style="-fx-text-fill: #5a8ab0; -fx-font-size: 10px;
                              -fx-font-weight: bold; -fx-padding: 0 0 6 6;" />

                <Button maxWidth="Infinity" onAction="#handleManageAppointments"
                        style="-fx-background-color: #1a4a7a; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 13 16;
                               -fx-alignment: CENTER-LEFT; -fx-font-size: 13px;
                               -fx-cursor: hand;"
                        text="Manage Appointments" />

                <Button maxWidth="Infinity" onAction="#handleManageUsers"
                        style="-fx-background-color: transparent; -fx-text-fill: #b8d4ee;
                               -fx-background-radius: 8; -fx-padding: 13 16;
                               -fx-alignment: CENTER-LEFT; -fx-font-size: 13px;
                               -fx-cursor: hand;"
                        text="Manage Users" />

                <Button maxWidth="Infinity" onAction="#handleAppointmentRequest"
                        style="-fx-background-color: transparent; -fx-text-fill: #b8d4ee;
                               -fx-background-radius: 8; -fx-padding: 13 16;
                               -fx-alignment: CENTER-LEFT; -fx-font-size: 13px;
                               -fx-cursor: hand;"
                        text="Appointment Requests" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox style="-fx-padding: 10 10 20 10;">
                <Button onAction="#handleLogout" maxWidth="Infinity"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-padding: 12 16;
                               -fx-alignment: CENTER-LEFT; -fx-font-size: 13px;
                               -fx-font-weight: bold; -fx-cursor: hand;"
                        text="Logout" />
            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="24.0" style="-fx-padding: 32 36 32 36;">

            <!-- Top Header -->
            <HBox alignment="CENTER_LEFT" spacing="14">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label fx:id="welcomeLabel"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0B2E5E;"
                           text="Welcome, Admin!" />
                    <Label text="Here's an overview of your clinic today."
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;" />
                </VBox>
            </HBox>

            <!-- Divider -->
            <Separator style="-fx-background-color: #dde4ee;" />

            <!-- Section Label -->
            <Label text="Dashboard Overview"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

            <!-- Stats Cards -->
            <HBox spacing="16.0" alignment="CENTER">

                <!-- Total Appointments -->
                <VBox spacing="8.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 22 20;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);"
                      HBox.hgrow="ALWAYS">
                    <Label text="Total Appointments"
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" />
                    <Label fx:id="totalAppointments" text="0"
                           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #0B2E5E;" />
                    <Label text="All time"
                           style="-fx-text-fill: #aab4c2; -fx-font-size: 11px;" />
                </VBox>

                <!-- Pending -->
                <VBox spacing="8.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 22 20;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);
                             -fx-border-left-color: #f39c12; -fx-border-width: 0 0 0 4;
                             -fx-border-radius: 0 12 12 0;"
                      HBox.hgrow="ALWAYS">
                    <Label text="Pending"
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" />
                    <Label fx:id="pendingAppointments" text="0"
                           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" />
                    <Label text="Awaiting approval"
                           style="-fx-text-fill: #aab4c2; -fx-font-size: 11px;" />
                </VBox>

                <!-- Approved -->
                <VBox spacing="8.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 22 20;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);"
                      HBox.hgrow="ALWAYS">
                    <Label text="Approved"
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" />
                    <Label fx:id="approvedAppointments" text="0"
                           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                    <Label text="Confirmed"
                           style="-fx-text-fill: #aab4c2; -fx-font-size: 11px;" />
                </VBox>

                <!-- Patients -->
                <VBox spacing="8.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 22 20;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);"
                      HBox.hgrow="ALWAYS">
                    <Label text="Patients"
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" />
                    <Label fx:id="totalPatients" text="0"
                           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2980b9;" />
                    <Label text="Registered"
                           style="-fx-text-fill: #aab4c2; -fx-font-size: 11px;" />
                </VBox>

                <!-- Doctors -->
                <VBox spacing="8.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 22 20;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);"
                      HBox.hgrow="ALWAYS">
                    <Label text="‍Doctors"
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" />
                    <Label fx:id="totalDoctors" text="0"
                           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #8e44ad;" />
                    <Label text="Active"
                           style="-fx-text-fill: #aab4c2; -fx-font-size: 11px;" />
                </VBox>

            </HBox>

            <!-- Quick Actions -->
            <VBox spacing="12">
                <Label text="Quick Actions"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <HBox spacing="14">
                    <Button onAction="#handleAppointmentRequest"
                            style="-fx-background-color: #e67e22; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-padding: 12 22;
                                   -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"
                            text="Review Pending Requests" />
                    <Button onAction="#handleManageAppointments"
                            style="-fx-background-color: #0B2E5E; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-padding: 12 22;
                                   -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"
                            text="View All Appointments" />
                    <Button onAction="#handleManageUsers"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-padding: 12 22;
                                   -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"
                            text="Manage Users" />
                </HBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>
