<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="460.0" spacing="0"
      style="-fx-background-color: white; -fx-background-radius: 14;
             -fx-border-radius: 14;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="caresync.controller.BookingModalController">

    <!-- Header Bar -->
    <VBox style="-fx-background-color: #0B2E5E; -fx-padding: 22 28 18 28;
                 -fx-background-radius: 14 14 0 0;" spacing="4">
        <Label text="Book New Appointment"
               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;" />
        <Label text="Fill in the details below to request an appointment"
               style="-fx-text-fill: #90aecb; -fx-font-size: 12px;" />
    </VBox>

    <!-- Form Body -->
    <VBox spacing="14" style="-fx-padding: 24 28 10 28;">

        <!-- Doctor -->
        <VBox spacing="5">
            <Label text="Select Doctor *"
                   style="-fx-text-fill: #444; -fx-font-size: 12px; -fx-font-weight: bold;" />
            <ComboBox fx:id="doctorSelect" maxWidth="Infinity"
                      promptText="Choose a doctor..."
                      style="-fx-background-radius: 8; -fx-border-color: #d0dce8;
                             -fx-border-radius: 8; -fx-background-color: #fafdff;
                             -fx-font-size: 13px;" />
        </VBox>

        <!-- Date -->
        <VBox spacing="5">
            <Label text="Appointment Date *"
                   style="-fx-text-fill: #444; -fx-font-size: 12px; -fx-font-weight: bold;" />
            <DatePicker fx:id="dateSelect" maxWidth="Infinity"
                        promptText="Select a future date"
                        style="-fx-background-radius: 8; -fx-border-color: #d0dce8;
                               -fx-border-radius: 8; -fx-background-color: #fafdff;
                               -fx-font-size: 13px;" />
        </VBox>

        <!-- Time -->
        <VBox spacing="5">
            <Label text="Appointment Time * (24-hour format)"
                   style="-fx-text-fill: #444; -fx-font-size: 12px; -fx-font-weight: bold;" />
            <TextField fx:id="timeSelect" promptText="e.g.  09:00  or  14:30"
                       style="-fx-background-radius: 8; -fx-border-color: #d0dce8;
                              -fx-border-radius: 8; -fx-background-color: #fafdff;
                              -fx-font-size: 13px; -fx-padding: 10;" />
            <Label text="Working hours: 9:00 AM – 5:00 PM only"
                   style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
        </VBox>

        <!-- Health Note -->
        <VBox spacing="5">
            <Label text="Health Note (Optional)"
                   style="-fx-text-fill: #444; -fx-font-size: 12px; -fx-font-weight: bold;" />
            <TextArea fx:id="healthNote" prefHeight="85.0" wrapText="true"
                      promptText="Briefly describe your symptoms or reason for visit..."
                      style="-fx-background-radius: 8; -fx-border-color: #d0dce8;
                             -fx-border-radius: 8; -fx-background-color: #fafdff;
                             -fx-font-size: 13px;" />
        </VBox>

    </VBox>

    <!-- Info Bar -->
    <HBox style="-fx-background-color: #eaf3fb; -fx-padding: 10 28; -fx-margin: 0 0 0 0;">
        <Label text="★  Required fields are marked with *  |  Appointments are subject to admin approval"
               style="-fx-text-fill: #2980b9; -fx-font-size: 11px;" />
    </HBox>

    <!-- Buttons -->
    <HBox spacing="12" alignment="CENTER"
          style="-fx-padding: 16 28 24 28;">
        <Button onAction="#handleCancel" prefWidth="185.0"
                style="-fx-background-color: white; -fx-text-fill: #555;
                       -fx-border-color: #ccc; -fx-border-radius: 8;
                       -fx-background-radius: 8; -fx-padding: 11;
                       -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand;"
                text="✕  Cancel" />
        <Button onAction="#handleBookingSubmit" prefWidth="185.0"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-background-radius: 8; -fx-padding: 11;
                       -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand;"
                text="✔  Confirm Booking" />
    </HBox>

</VBox>
